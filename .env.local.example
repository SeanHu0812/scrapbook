# Copy this file to .env.local and fill in the values from `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Apple OAuth — create at developer.apple.com > Certificates, Identifiers & Profiles
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Google OAuth — create at console.cloud.google.com > APIs & Services > Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend — for password-reset / magic-link emails (resend.com)
AUTH_RESEND_KEY=
